    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "Id": "505cb1f8e953476180377eba6b024a35",
      "NodeType": "CodeBlockNode",
      "Inputs": [],
      "Outputs": [
        {
          "Id": "25344a593d604a63b37560d622b7f89f",
          "Name": "double",
          "Description": "0.5",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Allows for DesignScript code to be authored directly",
      "Code": "0.5;"
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "#-Reope----------------------------------------#\r\n#                                              #\r\n#      Copyright(c) 2018, Dimitar Venkov       #\r\n#                                              #\r\n# https://github.com/dimven/SpringNodes/issues #\r\n# https://www.reope.com/                       #\r\n#                                              #\r\n#-Reope-----Updated by Mark Ackerley-----------#\r\n\r\nimport clr\r\n\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\nclr.AddReference('RevitServices')\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\nclr.AddReference('RevitAPI')\r\nimport Autodesk.Revit.DB as DB\r\n\r\n\r\ndef tolist(x):\r\n    if isinstance(x, str): return [x]\r\n    return x if isinstance(x, list) else [x]\r\n\r\ndef first(x):\r\n    return x[0] if isinstance(x, list) else x\r\n\r\ndef ds_point_to_xyz(pt):\r\n    \"\"\"Explicit conversion: DS Point → DB.XYZ\"\"\"\r\n    return DB.XYZ(pt.X, pt.Y, pt.Z)\r\n\r\ndef ds_vector_to_xyz(v):\r\n    \"\"\"Explicit conversion: DS Vector → DB.XYZ\"\"\"\r\n    return DB.XYZ(v.X, v.Y, v.Z)\r\n\r\n\r\ntry:\r\n    host = first(IN[0])\r\n    ftype = UnwrapElement(tolist(IN[1]))\r\n    pts = tolist(IN[2])\r\n\r\n    OUT = []\r\n    ftp_len = len(ftype) == 1\r\n    ref1 = host.Tags.LookupTag(\"RevitFaceReference\")\r\n\r\n    TransactionManager.Instance.EnsureInTransaction(doc)\r\n\r\n    for i, p in enumerate(pts):\r\n        j = 0 if ftp_len else i\r\n\r\n        if not ftype[j].IsActive:\r\n            ftype[j].Activate()\r\n\r\n        faceNor = host.NormalAtPoint(p)\r\n        up = Vector.ZAxis()\r\n\r\n        # horizontal?\r\n        if abs(faceNor.Dot(up)) > 0.9999:\r\n            dir1 = DB.XYZ.BasisX\r\n        else:\r\n            cross = faceNor.Cross(up)\r\n            dir1 = ds_vector_to_xyz(cross)\r\n            \r\n        xf = host.GetTransform()\r\n        pXyz = ds_point_to_xyz(p)\r\n        p_transform = xf.OfPoint(pXyz)    \r\n\r\n        try:\r\n            inst1 = doc.Create.NewFamilyInstance(\r\n                ref1,\r\n                p_transform,   # <-- EXPLICIT\r\n                dir1,                 # <-- EXPLICIT\r\n                ftype[j]\r\n            )\r\n            OUT.append(inst1.ToDSType(False))\r\n        except Exception as ex:\r\n            OUT.append(str(ex))\r\n\r\n    TransactionManager.Instance.TransactionTaskDone()\r\n\r\nexcept Exception as e:\r\n    import traceback\r\n    OUT = \"Exception:\\n{0}\\n\\nTraceback:\\n{1}\".format(\r\n        str(e),\r\n        traceback.format_exc()\r\n    )\r\n",
      "Engine": "PythonNet3",
      "VariableInputPorts": true,
      "Id": "80145fde6b354e3081b91d9c1a1f576b",
      "NodeType": "PythonScriptNode",
      "Inputs": [
        {
          "Id": "43b2bded06b84a8a9a9dac30e8da128c",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "49f4e900f0a6470e95201c1878c393aa",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "b671ce4849f84257a48d6c4455b4433a",
          "Name": "IN[2]",
          "Description": "Input #2",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "83be3e4518b0412ebeb1ee507948a43c",
          "Name": "OUT",
          "Description": "Result of the python script",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Runs an embedded Python script."
    },
