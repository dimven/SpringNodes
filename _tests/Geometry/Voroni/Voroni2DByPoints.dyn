    {
      "ConcreteType": "CoreNodeModels.Input.StringInput, CoreNodeModels",
      "SerializedWidth": 0.0,
      "SerializedHeight": 0.0,
      "Id": "305bb703d3fb4515ab136b6f0cda5060",
      "NodeType": "StringInputNode",
      "Inputs": [],
      "Outputs": [
        {
          "Id": "76a59343b9c34d7d8b0f550d95200b6e",
          "Name": "",
          "Description": "String",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Creates a string.",
      "InputValue": "import math\r\n\r\npts = []\r\nfor i in range(50):\r\n    angle = i * 137.5 * (math.pi / 180)  # golden angle\r\n    r = math.sqrt(i) * 2\r\n    x = r * math.cos(angle)\r\n    y = r * math.sin(angle)\r\n    pts.append((round(x, 3), round(y, 3)))\r\n\r\nOUT = [p for p in pts]"
    },
