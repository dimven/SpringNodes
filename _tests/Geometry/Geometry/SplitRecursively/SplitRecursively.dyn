      "Outputs": [
        {
          "Id": "06b3169f80b14e6f8a34c99b07ac0e88",
          "Name": "face",
          "Description": "face",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "3278bcaa44d74ba1a0ffa831a0c6f78d",
          "Name": "planes",
          "Description": "planes",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "942a07406638480fb2187269121711e2",
          "Name": "dir1",
          "Description": "dir1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "4f787f9aabd94a35a746ded4b6be6d83",
          "Name": "geom",
          "Description": "geom = [Imperative]\n{\noutp = [];\ni = 0;\nfor(p in planes)\n{\ns1 = face.Split(p);\nif(Count(s1) < 2)\n{\nface = DesignScript.Builtin.Get.ValueAtIndex(s1, 0);\ncontinue;\n}\nind1 = SortIndexByValue(dir1.DistanceTo(s1));\ns1 = Reorder(s1, ind1);\nface = DesignScript.Builtin.Get.ValueAtIndex(s1, 0);\ns2 = DesignScript.Builtin.Get.ValueAtIndex(s1, 1);\noutp[i] = DesignScript.Builtin.Get.ValueAtIndex(s1, 1);\ni = (i + 1);\n\n}\noutp[i] = face;\nreturn = outp;\n\n}\n",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Allows for DesignScript code to be authored directly",
      "Code": "face;\nplanes;\ndir1;\ngeom = [Imperative]{\noutp = [];\ni = 0;\nfor (p in planes){\n\ts1 = face.Split(p);\n\tif(Count(s1) < 2){\n\t\tface = s1[0];\n\t\tcontinue;\n\t}\n\tind1 = SortIndexByValue(\n\t\tdir1.DistanceTo(s1) );\n\ts1 = Reorder(s1,ind1);\n\tface = s1[0];\n\ts2 = s1[1];\n\toutp[i] = s1[1];\n\ti = i + 1;\n}\noutp[i] = face;\nreturn = outp;\n};"
    }
