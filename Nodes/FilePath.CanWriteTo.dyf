  "Nodes": [
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "#----------------------------------------------#\r\n#                                              #\r\n#      Copyright(c) 2020, Dimitar Venkov       #\r\n#                                              #\r\n# https://github.com/dimven/SpringNodes/issues #\r\n# https://www.reope.com/                       #\r\n#                                              #\r\n#    ____    _____   _____   ____    _____     #\r\n#   |  _ \\ *|  ___|*|  _  |*|  _ \\ *|  ___|    #\r\n#   | |_) |*| |___ *| | | |*| |_) |*| |___     #\r\n#   |  _ < *|  ___|*| | | |*|  __/ *|  ___|    #\r\n#   | | | |*| |___ *| |_| |*| |    *| |___     #\r\n#   |_| \\_|*|_____|*|_____|*|_|    *|_____|    #\r\n#                                              #\r\n#                                              #\r\n#-----------Updated by Mark Ackerley-----------#\r\n\r\n\r\nimport clr\r\nimport traceback\r\n\r\nclr.AddReference(\"System.IO\")\r\nfrom System.IO import File, Path, Directory, FileOptions\r\n\r\ndef tolist(obj1):\r\n    return obj1 if isinstance(obj1, list) else [obj1]\r\n\r\ndef getDirectory(p):\r\n    if File.Exists(p):\r\n        return Path.GetDirectoryName(p)\r\n    if Directory.Exists(p):\r\n        return p\r\n    return None\r\n\r\ndef canWriteToDir(d):\r\n    try:\r\n        f = File.Create(Path.Combine(d, \"__test_file_name__\"), 1, FileOptions.DeleteOnClose)\r\n        f.Close()\r\n        return True\r\n    except Exception as e:\r\n        msg = str(e)\r\n        if \"Access to the path\" in msg and \"is denied\" in msg:\r\n            return \"Access denied - administrator rights required\"\r\n        return \"Cannot write: {0}\".format(msg.splitlines()[0])\r\n\r\nOUT = []\r\n\r\ntry:\r\n    paths = tolist(IN[0])\r\n    for p in paths:\r\n        d = getDirectory(p)\r\n        if d is not None:\r\n            OUT.append(canWriteToDir(d))\r\n        else:\r\n            OUT.append(False)\r\nexcept Exception as e:\r\n    OUT = \"Exception:\\n{0}\\n\\nTraceback:\\n{1}\".format(\r\n        str(e),\r\n        traceback.format_exc()\r\n    )\r\n",
