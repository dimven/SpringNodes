        {
          "Id": "3bf4940869d04d99a42e0e1aaaa563a6",
          "Name": "mesh",
          "Description": "mesh",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "f501d80ddd59414ebfa1469d8621359d",
          "Name": "vp",
          "Description": "vp = mesh.VertexPositions",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "f2b53b7e3932462bb19a333883ce7323",
          "Name": "fi",
          "Description": "fi = DSCore.List.Flatten(mesh.FaceIndices)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "563453934c4e432999e894efce8570e0",
          "Name": "hasQuad",
          "Description": "hasQuad = (fi.D) != null",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "95cbe399169c40fcb035866d43f4dc45",
          "Name": "verts",
          "Description": "verts = QuadToTrianglesVP(vp)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "864321b5f637437cbe5e3e1d066f2f09",
          "Name": "inds",
          "Description": "inds = List.Flatten(QuadToTrianglesFi(fi), 1)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "f0524257bdd84e8597e0a3126616d43d",
          "Name": "tkMesh",
          "Description": "tkMesh = Autodesk.Dynamo.MeshToolkit.Mesh.ByVerticesAndIndices(verts@L2<1>, inds@L2<1>)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Allows for DesignScript code to be authored directly",
      "Code": "// function to convert a quad (4 points) into two tri-meshes\ndef QuadToTrianglesVP(vp)\n{\n    // mesh vertex positions are points\n    // we need to convert 1 list of 4 points into\n    // 2 lists of 3 points, this translation should work\n    vps = List.GetItemAtIndex(vp@L2<1>, 0);\n    // so for each mesh passed in, we get it's points and reorder\n    // we return lists of the 0 points, 1 points etc.\n    vp1 = List.GetItemAtIndex(vps@L2<1>, 0);\n    vp2 = List.GetItemAtIndex(vps@L2<1>, 1);\n    vp3 = List.GetItemAtIndex(vps@L2<1>, 2);\n    vps1 = [vp1, vp2, vp3];\n\n    vp4 = List.GetItemAtIndex(vp@L2<1>, 0);\n    vp5 = List.GetItemAtIndex(vp@L2<1>, 2);\n    vp6 = List.GetItemAtIndex(vp@L2<1>, 3);\n    vps2 = [vp4, vp5, vp6];\n\n    // we transpose to give us the points for each mesh\n    // in their own sub list\n    vpt1 = List.Flatten(List.Transpose(vps1));\n    vpt2 = List.Flatten(List.Transpose(vps2));\n\n    // these are now the 2 tri-meshes from the quad\n    vpLots = [vpt1, vpt2];\n\n    return vps1;\n};\n\ndef QuadToTrianglesFi(fi)\n{\n    // face indices are the number we want to place\n    // tk meshes are only tri-face, so we don't want\n    // a list containing 4... we just need as many lists\n    // of 3 as we are providing points for.\n    // the translation from 4 to 3 is primarily governed by\n    // the point position\n    fif = List.Flatten(fi,1);\n    fifT = List.Transpose([fif.A, fif.B, fif.C]);\n    return fifT;\n};\n// simple function to deal with 3 points, returning consitantly\n// with the other function\n\nvp = mesh.VertexPositions;\nfi = DSCore.List.Flatten(mesh.FaceIndices);\n// if it's a quad it's not a straight translation\n// we'll need to break it down\nhasQuad = fi.D != null;\nverts = QuadToTrianglesVP(vp);\ninds  = List.Flatten(QuadToTrianglesFi(fi),1);\ntkMesh = Dynamo.Mesh.ByVerticesAndIndices(verts@L2<1>, inds@L2<1>);"
    },
