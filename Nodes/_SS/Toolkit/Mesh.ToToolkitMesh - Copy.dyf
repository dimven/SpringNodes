        },
        {
          "Id": "1d59cdb7e2194b9a8df20e0ec5c3d0e6",
          "Name": "",
          "Description": "vp",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "e83f87638506457c98e15ecd6ddb9f2b",
          "Name": "",
          "Description": "s1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "e7eec51ef0014d1fb153c58192ebf292",
          "Name": "",
          "Description": "fi2",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "3051fc81aeb44b92ae042e31812db897",
          "Name": "",
          "Description": "tkMesh",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Allows for DesignScript code to be authored directly",
      "Code": "fi = m1.FaceIndices;\nvp = m1.VertexPositions;\ns1 = DSCore.List.Transpose([fi.A,fi.B,fi.C]);\nfi2 = DSCore.List.Flatten(s1);\ntkMesh = Dynamo.Mesh.ByVerticesAndIndices(vp,fi2);"
    },
