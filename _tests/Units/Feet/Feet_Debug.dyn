    {
      "ConcreteType": "Dynamo.Graph.Nodes.CodeBlockNodeModel, DynamoCore",
      "Id": "b25340192df94938addd7188e72cb9f6",
      "NodeType": "CodeBlockNode",
      "Inputs": [
        {
          "Id": "33393de5d8e04b9d91d6326c595d1563",
          "Name": "_x",
          "Description": "_x",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "899cb6828c9745d693e40a80e4d95588",
          "Name": "f1",
          "Description": "f1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "186c76989aee4ac8afa21e1f869328d1",
          "Name": "sign",
          "Description": "sign = ((_x < 0 ? \"-\" : \"\"))",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "505b442d6c99410b8881b562d6e266ac",
          "Name": "x",
          "Description": "x = DSCore.Math.Abs(_x)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "82fe3f0c9f544cf7b03567f8abf181b4",
          "Name": "frac",
          "Description": "frac = DSCore.Math.Pow(2, 1..8)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "5973ca78cc65402a9228c4ed62b787bd",
          "Name": "ft1",
          "Description": "ft1 = DSCore.Math.Floor(x)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "a0d43cef534345c0ad539446f52874cd",
          "Name": "in1",
          "Description": "in1 = (x - ft1) * 12",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "f5cea8cabb3745c7a27786f4c6e0ef9d",
          "Name": "in2",
          "Description": "in2 = DSCore.Math.Floor(in1)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "0c5e2aead85245548288fdf7d8366290",
          "Name": "fr1",
          "Description": "fr1 = (in1 - in2) * frac",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "8be2fe4d99024ab9aa842b3e217e2950",
          "Name": "fr2",
          "Description": "fr2 = DSCore.Math.Round(fr1)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "4c86347771a24fd88c37e3b04da73fa6",
          "Name": "v1",
          "Description": "v1 = DSCore.Math.Abs(fr1 - fr2)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "d752b70425f04d5f85d82c1902b89013",
          "Name": "ind1",
          "Description": "ind1 = DSCore.List.FirstIndexOf(v1, DSCore.List.MinimumItem(v1))",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "09253c10119141659949c1dd23d5ffe0",
          "Name": "fr3",
          "Description": "fr3 = DesignScript.Builtin.Get.ValueAtIndex(((__Apply(f1, DesignScript.Builtin.Get.ValueAtIndex(fr2, ind1))) + \"/\") + (__Apply(f1, DesignScript.Builtin.Get.ValueAtIndex(frac, ind1))), 0)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "40d2fa05ac174c6185b3b630a18553ad",
          "Name": "t0",
          "Description": "t0 = (DSCore.String.Substring(fr3, 0, 1)) == (DSCore.String.Substring(fr3, -1, 1))",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "e1ecd180ea2a470f9d039f0709f2a501",
          "Name": "in3",
          "Description": "in3 = ((t0 ? in2 + 1 : in2))",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "cbb476c758ed4b5981e324dd38d67a1a",
          "Name": "ft1s",
          "Description": "ft1s = (DesignScript.Builtin.Get.ValueAtIndex(__Apply(f1, ft1), 0)) + \"'\"",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "f4f3e63bee1d473c84fed213142ecb56",
          "Name": "in3s",
          "Description": "in3s = DesignScript.Builtin.Get.ValueAtIndex(__Apply(f1, in3), 0)",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "5a15966b66ce4b1f8f17d4b36fa5fa7b",
          "Name": "ft1str",
          "Description": "ft1str = ((ft1s == \"0'\" ? \"\" : ft1s))",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "3216913d1c0c450295a2d88361f80487",
          "Name": "t1",
          "Description": "t1 = in3 == 0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "6b25e2b287bb4e388f63dce59362adeb",
          "Name": "t2",
          "Description": "t2 = fr3 == \"0/2\"",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "bd4bea0373cc4ff1a7aa048aba25f928",
          "Name": "in2s",
          "Description": "in2s = ((t1 ? \"\" : in3s))",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "b491a629e1b74a408c7c23eec19568d3",
          "Name": "fr3s",
          "Description": "fr3s = ((t2 || t0 ? \"\" : fr3))",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "a26b8e03e3884dca976948bcf21c15ba",
          "Name": "mid",
          "Description": "mid = (((t1 || t2) || t0 ? \"\" : \" \"))",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "e57e077413d142a4881a2fd3db059487",
          "Name": "end",
          "Description": "end = ((t1 && t2 ? \"\" : \"\"\"))",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "40ded3ae0f8e41139be6a86e4871aebb",
          "Name": "function",
          "Description": "((((sign + ft1str) + in2s) + mid) + fr3s) + end",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Allows for DesignScript code to be authored directly",
      "Code": "sign = _x < 0 ? \"-\" : \"\";\nx = Math.Abs(_x);\nfrac = Math.Pow(2, 1..8);\nft1 = Math.Floor(x);\nin1 = (x - ft1) * 12;\nin2 = Math.Floor(in1);\nfr1 = (in1 - in2) * frac;\nfr2 = Math.Round(fr1);\nv1 = Math.Abs(fr1 - fr2);\nind1 = DSCore.List.FirstIndexOf(v1, DSCore.List.MinimumItem(v1));\nfr3 = (__Apply(f1,fr2[ind1]) + \"/\" + __Apply(f1,frac[ind1]) )[0];\nt0 = String.Substring(fr3, 0, 1) == String.Substring(fr3, -1, 1);\nin3 = t0 ? (in2 + 1) : in2;\nft1s = __Apply(f1,ft1)[0] + \"'\";\nin3s = __Apply(f1,in3)[0];\nft1str = ft1s == \"0'\" ? \"\" : ft1s;\nt1 = in3 == 0;\nt2 = fr3 == \"0/2\";\nin2s = t1 ? \"\" : in3s;\nfr3s = t2 || t0 ? \"\" : fr3;\nmid = t1 || t2 || t0 ? \"\" : \" \";\nend = t1 && t2 ? \"\" : \"\\\"\";\nsign+ft1str+in2s+mid+fr3s+end;"
    },
