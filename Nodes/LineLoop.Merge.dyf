    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "Code": "#----------------------------------------------#\r\n#                                              #\r\n#      Copyright(c) 2016, Dimitar Venkov       #\r\n#                                              #\r\n# https://github.com/dimven/SpringNodes/issues #\r\n# https://www.reope.com/                       #\r\n#                                              #\r\n#    ____    _____   _____   ____    _____     #\r\n#   |  _ \\ *|  ___|*|  _  |*|  _ \\ *|  ___|    #\r\n#   | |_) |*| |___ *| | | |*| |_) |*| |___     #\r\n#   |  _ < *|  ___|*| | | |*|  __/ *|  ___|    #\r\n#   | | | |*| |___ *| |_| |*| |    *| |___     #\r\n#   |_| \\_|*|_____|*|_____|*|_|    *|_____|    #\r\n#                                              #    \r\n#                                              #\r\n#-----------Updated by Mark Ackerley-----------#\r\n\r\nimport clr\r\nclr.AddReference('ProtoGeometry')\r\nfrom Autodesk.DesignScript.Geometry import *\r\n\r\ncurves = IN[0]\r\nmargin = IN[1]\r\noriginal = curves[:]\r\n\r\noutput = []  # collect all intermediate values here\r\n\r\ndef endpointsTouch(c1, c2, tol=0.001):\r\n    return bool(c1.Intersect(c2))\r\n\r\n\r\ndef sharedPoint(c1, c2):\r\n    pts = c1.Intersect(c2)\r\n    for pt in pts:\r\n        if hasattr(pt, \"X\") and hasattr(pt, \"Y\") and hasattr(pt, \"Z\"):\r\n            return pt\r\n        elif hasattr(pt, \"PointAtParameter\"):\r\n            return pt.PointAtParameter(0.5)\r\n    return None\r\n\r\ndef switch1(i, j, cl0, cl1):\r\n    cl0[i], cl0[j] = cl0[j], cl0[i]\r\n    cl1[i], cl1[j] = cl1[j], cl1[i]\r\n\r\ndef OrderCurves(cl0, cl1):\r\n    _ln = len(cl1)\r\n    xr1 = range(_ln)\r\n    int_test = [[endpointsTouch(cl1[i], cl1[j]) for j in xr1 if j != i] for i in xr1]\r\n    output.append([\"intersection matrix\", int_test])\r\n    countT = list(map(sum, int_test))\r\n    output.append([\"intersection counts\", countT])\r\n\r\n    if 0 not in countT:\r\n        if 1 in countT and countT[0] != 1:\r\n            switch1(0, countT.index(1), cl0, cl1)\r\n        for i in range(_ln - 1):\r\n            k = i + 1\r\n            if endpointsTouch(cl1[i], cl1[k]):\r\n                continue\r\n            try:\r\n                int_test = [endpointsTouch(cl1[i], cl1[j]) for j in range(k, _ln)]\r\n                switch1(k, k + int_test.index(True), cl0, cl1)\r\n            except Exception as e:\r\n                output.append([\"ordering exception\", str(e)])\r\n    return cl0, cl1\r\n\r\ndef ClosedCase(cl0, cl1):\r\n    pts = []\r\n    for i in range(len(cl1)):\r\n        pt = sharedPoint(cl1[i - 1], cl1[i])\r\n        if pt is None:\r\n            output.append([\"closed case fail\", i])\r\n            raise ValueError(\"No shared point at index {}\".format(i))\r\n        pts.append(pt)\r\n    output.append([\"closed case points\", pts])\r\n    return PolyCurve.ByPoints(pts, True)\r\n\r\ndef OpenCase(cl0, cl1):\r\n    def FarPt(l1, p1):\r\n        pts = (l1.StartPoint, l1.EndPoint)\r\n        return max(pts, key=lambda pt: p1.DistanceTo(pt))\r\n\r\n    pts = []\r\n    for i in range(len(cl1) - 1):\r\n        pt = sharedPoint(cl1[i], cl1[i + 1])\r\n        if pt is None:\r\n            output.append([\"open case fail\", i])\r\n            raise ValueError(\"No shared point at index {}\".format(i))\r\n        pts.append(pt)\r\n\r\n    pts.append(FarPt(cl0[-1], pts[-1]))\r\n    pts.insert(0, FarPt(cl0[0], pts[0]))\r\n    output.append([\"open case points\", pts])\r\n    return PolyCurve.ByPoints(pts)\r\n\r\ndef joinCurves(cl0, th1):\r\n    len1 = len(cl0)\r\n    if len1 < 2:\r\n        return cl0, False\r\n    else:\r\n        cl1 = []\r\n        for c in cl0:\r\n            c1 = c.ExtendStart(th1)\r\n            c2 = c1.ExtendEnd(th1) if c1 else None\r\n            if not c2:\r\n                output.append([\"extension fail\", c])\r\n                raise ValueError(\"Curve extension failed\")\r\n            cl1.append(c2)\r\n\r\n        output.append([\"extended curves\", cl1])\r\n        cl0, cl1 = OrderCurves(cl0, cl1)\r\n        output.append([\"ordered original\", cl0])\r\n        output.append([\"ordered extended\", cl1])\r\n\r\n        isClosed = endpointsTouch(cl1[0], cl1[-1]) and len1 > 2\r\n        output.append([\"isClosed\", isClosed])\r\n        _fn = ClosedCase if isClosed else OpenCase\r\n\r\n        try:\r\n            result = _fn(cl0, cl1)\r\n            return result, True\r\n        except Exception as e:\r\n            output.append([\"join exception\", str(e)])\r\n            return cl0, False\r\n\r\ndef ReorderCurves(orig, new):\r\n    reordered, new = [], list(new)\r\n    app1, pop1, PaP = reordered.append, new.pop, Curve.PointAtParameter\r\n\r\n    for i in range(len(orig)):\r\n        p1 = PaP(orig[i], 0.5)\r\n        p2 = [PaP(new[j], 0.5) for j in range(len(new))]\r\n        ind1 = p2.index(min(p2, key=lambda pt: p1.DistanceTo(pt)))\r\n        app1(pop1(ind1))\r\n    output.append([\"reordered curves\", reordered])\r\n    return reordered\r\n\r\n# Run code\r\nout1 = joinCurves(curves, margin)\r\n\r\ntry:\r\n    joined = out1[0]\r\n    # If joined is a PolyCurve, extract its segments for reordering\r\n    if hasattr(joined, \"Curves\"):\r\n        reordered = ReorderCurves(original, joined.Curves())\r\n    # If joined is already a list of curves, pass through\r\n    elif isinstance(joined, list):\r\n        reordered = ReorderCurves(original, joined)\r\n    # If joined is a single curve, wrap it in a list\r\n    else:\r\n        reordered = ReorderCurves(original, [joined])\r\n\r\n    OUT = [(joined), (reordered), (out1[1]), (\"debug\", output)]\r\n\r\nexcept Exception as e:\r\n    import traceback\r\n    OUT = [(\"exception\", str(e)), (\"traceback\", traceback.format_exc()), (\"debug\", output)]",
      "Engine": "PythonNet3",
      "VariableInputPorts": true,
      "Id": "f8654d051a304239a384e2b4f6b28d23",
      "NodeType": "PythonScriptNode",
