  "Uuid": "499c1950-fa4e-4a62-9778-4d888a01e7b4",
  "IsCustomNode": true,
  "Category": "Springs.FileSystem.Query",
  "Description": "Checks if the user and application has write access to the specified path's directory",
  "Name": "FilePath.CanWriteTo",
  "ElementResolver": {
    "ResolutionMap": {
