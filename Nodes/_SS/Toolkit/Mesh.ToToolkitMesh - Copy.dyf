          "KeepListStructure": false
        },
        {
          "Id": "7a387fcb339f43eab8248bd4dc01e252",
          "Name": "",
          "Description": "vp5",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "62715cb1430e49b99e28b94049a6047a",
          "Name": "",
          "Description": "vp6",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "d5f4c721aba740e2948ddd67bff5381c",
          "Name": "",
          "Description": "vps2",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "119ad8be6b7e4d12ae7173bc8e1e21a5",
          "Name": "",
          "Description": "vpt1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "6ea0761a3cb34d6b96bc22b297958bb2",
          "Name": "",
          "Description": "vpt2",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "ed43d6a381b247c8ad8d28c84df01ffc",
          "Name": "",
          "Description": "vpLots",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "d6ffed2700a34d3bb4196dea81ec8ba8",
          "Name": "",
          "Description": "fif",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "baa575cbe3e640e288139d537fa10b75",
          "Name": "",
          "Description": "fifT",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "031fe8b7e6cc412fa1a9ca99cafeb804",
          "Name": "",
          "Description": "tkMesh",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Allows for DesignScript code to be authored directly",
      "Code": "fi = m1.FaceIndices;\nvp =DSCore.List.Flatten(m1.VertexPositions);\nfis = DSCore.List.Flatten(fi);\n// mesh vertiex positions are points\n// we need to convert 1 list of 4 points into\n// 2 lists of 3 points, this translation should work\nvp1 = List.GetItemAtIndex(vp@L2<1>, 0);\nvp2 = List.GetItemAtIndex(vp@L2<1>, 1);\nvp3 = List.GetItemAtIndex(vp@L2<1>, 2);\nvps1 = [vp1, vp2, vp3];\nvp4 = List.GetItemAtIndex(vp@L2<1>, 0);\nvp5 = List.GetItemAtIndex(vp@L2<1>, 2);\nvp6 = List.GetItemAtIndex(vp@L2<1>, 3);\nvps2 = [vp4, vp5, vp6];\n// we transpose to give us the points for each mesh\n// in their own sub list\nvpt1 = List.Transpose(vps1);\nvpt2= List.Transpose(vps2);\n// these are now the 2 tri-meshes from the quad\nvpLots = [vpt1, vpt2];\n// face indices are the number we want to place\n// tk meshes are only tri-face, so we don't want\n// a list containing 4... we just need as many lists\n// of 3 as we are providing points for.\n// the translation from 4 to 3 is primarily governed by\n// the point positions\nfif = List.Flatten(fi, -1);\nfifT = List.Transpose([fif.A, fif.B, fif.C]);\ntkMesh = Dynamo.Mesh.ByVerticesAndIndices(vpLots,fifT);"
    },
