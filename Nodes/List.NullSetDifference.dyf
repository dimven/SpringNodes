        {
          "Id": "ce8bc855cf6b4479bda460461411ad53",
          "Name": "res",
          "Description": "res = [Imperative]\n{\nif(oldl != null)\n{\nreturn = SetDifference(newl, oldl);\n\n}\nelse\n{\nreturn = newl;\n\n}\n\n}\n",
